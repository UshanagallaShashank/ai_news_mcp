# ============================================================
# AI News MCP Server — Environment Variables
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in YOUR values below
# 3. Never commit .env to git! (it's in .gitignore)
# ============================================================


# ── Google AI (Gemini) ───────────────────────────────────────
# Get a FREE API key from: https://aistudio.google.com/apikey
# Free tier: 15 requests/minute, 1 million tokens/day — plenty for this bot
GOOGLE_API_KEY=your_google_api_key_here

# Set to TRUE if using Google Cloud Vertex AI instead of AI Studio
# Leave as FALSE for free AI Studio tier
GOOGLE_GENAI_USE_VERTEXAI=FALSE


# ── Telegram Bot ─────────────────────────────────────────────
# Step 1: Open Telegram and search for @BotFather
# Step 2: Send /newbot and follow the instructions
# Step 3: Copy the token (looks like: 123456789:ABCdef...)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Where to send the daily news digest
# Options:
#   Your user ID:  Get from @userinfobot on Telegram (e.g. 123456789)
#   A group ID:    Add bot to group, get ID from @userinfobot (e.g. -987654321)
#   A channel:     Get the channel ID (e.g. -1001234567890)
TELEGRAM_CHAT_ID=your_chat_id_here


# ── App Server ───────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080


# ── Webhook (Production Only) ────────────────────────────────
# Your public HTTPS URL where Telegram will send updates
# Examples:
#   GCP Cloud Run: https://ai-news-bot-xxxx-uc.a.run.app
#   Railway:       https://your-project.up.railway.app
#   Render:        https://your-service.onrender.com
#
# Leave EMPTY for local development (dev.py uses polling instead)
WEBHOOK_URL=


# ── News Scraping ─────────────────────────────────────────────
# Sources (all free, no API keys needed):
#   marktechpost → RSS feed  (AI/ML research)
#   hackernews   → Algolia API  (tech community)
#   devto        → Public API  (developer articles)
NEWS_LIMIT=6           # 6 total = 2 per source (3 sources)
NEWS_CACHE_TTL=1800    # Cache duration in seconds (1800 = 30 minutes)


# ── Auto-Send Schedule (UTC) ──────────────────────────────────
# Send news every day at this time (UTC timezone)
# 9 AM UTC = 2 AM PST / 5 AM EST / 11 AM CET / 2:30 PM IST
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0
